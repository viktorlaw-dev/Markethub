{
    "name": "viktorlaw/markethub",
    "description": "Multi-vendor marketplace WordPress theme",
    "type": "wordpress-theme",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Viktor Lawrence",
            "email": "your-email@example.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MarketHub\\": "inc/"
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=WordPress-Core inc/",
        "phpcbf": "phpcbf --standard=WordPress-Core inc/"
    }
}
